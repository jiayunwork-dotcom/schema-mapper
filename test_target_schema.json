{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UserProfile",
  "type": "object",
  "properties": {
    "userId": {
      "type": "integer",
      "description": "User identifier"
    },
    "userName": {
      "type": "string",
      "description": "Display name"
    },
    "emailAddress": {
      "type": "string",
      "format": "email"
    },
    "userAge": {
      "type": "number"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "street": {
      "type": "string"
    },
    "city": {
      "type": "string"
    },
    "postalCode": {
      "type": "string"
    },
    "userTags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "accountStatus": {
      "type": "string"
    }
  },
  "required": ["userId", "userName", "emailAddress"]
}
